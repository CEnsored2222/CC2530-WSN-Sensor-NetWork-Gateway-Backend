# ============================================================
# Smart Home IoT 部署环境变量
# 用法: cp .env.example .env  然后修改对应值
# ============================================================

# ====== MySQL ======
MYSQL_ROOT_PASSWORD=1234        # 生产环境务必修改
MYSQL_PORT=3306                    # 不想外部访问可改为 127.0.0.1:3306:3306

# ====== EMQX ======
EMQX_MQTT_PORT=1883                # MQTT TCP 端口(网关连接)
EMQX_WS_PORT=8083                  # MQTT over WebSocket
EMQX_DASHBOARD_PORT=18083          # EMQX 管理面板
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASS=public         # 生产环境务必修改
EMQX_USERNAME=                     # 后端连接 EMQX 的用户名(可空)
EMQX_PASSWORD=                     # 后端连接 EMQX 的密码(可空)

# ====== 后端 ======
SECRET_KEY=change-me-in-prod       # Flask session 密钥
JWT_SECRET=change-me-in-prod       # JWT 签名密钥
ADMIN_USERNAME=admin               # 初始管理员用户名
ADMIN_PASSWORD=admin123            # 初始管理员密码(首次启动后请修改)
BACKEND_PORT=5000                  # 不想外部访问可改为 127.0.0.1:5000:5000

# ====== 前端 ======
WEB_PORT=80                        # V1.0 浏览器访问端口
WEB_PORT_V2=81                     # V2.0 浏览器访问端口
